// 测试异步函数和等待表达式的工作原理
// ===================================

// 定义异步函数 - 获取用户数据
异步 函数 获取用户数据(user_id)
    打印(f"正在获取用户 {user_id} 的数据...")
    等待 睡眠(0.5) // 模拟网络请求延迟
    返回 {
        "id": user_id,
        "姓名": f"用户{user_id}",
        "年龄": 20 + user_id,
        "邮箱": f"user{user_id}@example.com"
    }

// 定义异步函数 - 发送通知
异步 函数 发送通知(user)
    打印(f"正在发送通知给 {user.姓名}...")
    等待 睡眠(0.3) // 模拟通知发送延迟
    返回 f"通知发送成功给 {user.姓名}"

// 定义主函数 - 执行顺序操作
异步 函数 主函数()
    打印("=== 顺序操作测试 ===")
    打印()

    // 1. 获取用户数据
    定义 user1 = 等待 获取用户数据(1)
    打印(f"获取到用户数据: {user1}")
    打印()

    // 2. 发送通知
    定义 通知结果 = 等待 发送通知(user1)
    打印(f"通知发送结果: {通知结果}")
    打印()

    // 3. 再次获取用户数据，验证异步调用
    定义 user2 = 等待 获取用户数据(2)
    打印(f"获取到用户数据: {user2}")
    打印()

// 定义测试函数 - 测试并发操作
异步 函数 并发操作测试()
    打印("=== 并发操作测试 ===")
    打印()

    // 同时获取多个用户数据
    定义 任务列表 = [
        获取用户数据(3),
        获取用户数据(4),
        获取用户数据(5)
    ]

    打印("正在并发获取多个用户数据...")
    定义 所有结果 = 等待 全部(任务列表)
    打印(f"所有用户数据获取完成:")

    遍历 用户 in 所有结果
        打印(f"  - 用户{用户.id}: {用户.姓名}")

// 定义测试函数 - 测试竞速操作
异步 函数 竞速操作测试()
    打印("=== 竞速操作测试 ===")
    打印()

    // 定义不同延迟的函数
    异步 函数 快速操作()
        等待 睡眠(0.2)
        打印("快速操作完成")
        返回 "快速操作"

    异步 函数 中速操作()
        等待 睡眠(0.5)
        打印("中速操作完成")
        返回 "中速操作"

    异步 函数 慢速操作()
        等待 睡眠(0.8)
        打印("慢速操作完成")
        返回 "慢速操作"

    // 竞速测试
    打印("三个操作正在竞速...")
    定义 获胜者 = 等待 竞速([快速操作(), 中速操作(), 慢速操作()])
    打印()
    打印(f"获胜操作: {获胜者}")

// 运行所有测试
打印("开始执行所有测试...")
等待 主函数()
等待 并发操作测试()
等待 竞速操作测试()
打印()
打印("所有测试完成！")
