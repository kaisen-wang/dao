异步 函数 延迟执行(名称, 毫秒)
    打印("开始执行", 名称)
    睡眠(毫秒 / 1000)
    打印("完成执行", 名称, "耗时", 毫秒, "毫秒")
    返回 毫秒

异步 函数 并发任务()
    定义 任务1 = 延迟执行("任务1", 1500)
    定义 任务2 = 延迟执行("任务2", 1000)
    定义 任务3 = 延迟执行("任务3", 2000)

    打印("等待所有任务完成")
    定义 结果 = 等待 全部(任务1, 任务2, 任务3)
    打印("所有任务结果:", 结果)
    返回 结果

异步 函数 竞速任务()
    定义 任务A = 延迟执行("任务A", 1500)
    定义 任务B = 延迟执行("任务B", 1000)
    定义 任务C = 延迟执行("任务C", 500)

    打印("等待最快任务完成")
    定义 结果 = 等待 竞速(任务A, 任务B, 任务C)
    打印("最快任务结果:", 结果)
    返回 结果

异步 函数 主程序()
    打印("=== 并发编程演示 ===")

    打印("\n1. 测试异步函数延迟执行")
