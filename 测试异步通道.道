异步 函数 发送者(通道, 消息, 延迟)
    等待 睡眠(延迟)
    发送 通道 消息
    打印("发送成功:", 消息)

异步 函数 接收者(通道, 名称, 延迟)
    等待 睡眠(延迟)
    定义 结果 = 接收 通道
    打印(名称, "收到:", 结果)
    返回 结果

异步 函数 主程序()
    打印("=== 异步通道通信测试 ===")

    定义 ch = 通道()

    // 发送一个消息，然后立即接收
    并行
        发送者(ch, "消息1", 0.5)
    并行
        接收者(ch, "接收者1", 0.6)

    等待 睡眠(1.0)

    // 再次发送和接收
    并行
        发送者(ch, "消息2", 0.1)
    并行
        接收者(ch, "接收者2", 0.2)

    等待 睡眠(0.5)

    // 测试缓冲通道
    定义 bc = 通道(2)  // 缓冲容量为2

    并行
        发送者(bc, "缓冲消息1", 0.1)
    并行
        发送者(bc, "缓冲消息2", 0.2)
    并行
        发送者(bc, "缓冲消息3", 0.3)
    并行
        接收者(bc, "缓冲接收者1", 0.4)
    并行
        接收者(bc, "缓冲接收者2", 0.5)
    并行
        接收者(bc, "缓冲接收者3", 0.6)

    等待 睡眠(1.0)

    打印("✅ 所有测试完成!")

等待 主程序()
