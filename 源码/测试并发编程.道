"""
道语言并发编程综合测试
======================
测试异步函数、等待操作、协程和通道的综合功能。
"""

异步 函数 生成数据(data_channel)
    打印("开始生成数据...")
    遍历 i 从 1 到 5
        睡眠(0.2)
        发送 data_channel, i * i
        打印("发送数据:", i*i)

    关闭(data_channel)
    打印("数据发送完成")


异步 函数 处理数据(input_channel, output_channel)
    打印("开始处理数据...")

    遍历 数据 在 input_channel
        睡眠(0.3)
        处理后数据 = 数据 * 2
        发送 output_channel, 处理后数据
        打印("处理数据:", 数据, "->", 处理后数据)

    关闭(output_channel)
    打印("数据处理完成")


异步 函数 保存结果(result_channel)
    打印("开始保存结果...")
    定义 结果 = []

    遍历 数据 在 result_channel
        睡眠(0.1)
        结果.追加(数据)
        打印("保存数据:", 数据)

    打印("最终结果:", 结果)
    返回 结果


异步 函数 主()
    打印("=== 道语言并发编程综合测试 ===")
    打印()

    定义 源通道 = 通道()
    定义 处理通道 = 通道()
    定义 结果通道 = 通道()

    定义 任务1 = 生成数据(源通道)
    定义 任务2 = 处理数据(源通道, 处理通道)
    定义 任务3 = 保存结果(处理通道)

    定义 最终结果 = 等待 全部([任务1, 任务2, 任务3])
    打印()
    打印("所有任务完成!")


运行异步(主())
