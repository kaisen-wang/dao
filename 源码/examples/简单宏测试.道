// 简单宏测试程序
// 验证缩进风格宏语法是否正常工作

// 定义一个简单的加一宏
定义宏 加一(x)
    返回 引述 $x + 1

// 使用宏
设 结果1 = !加一(5)
打印("加一(5):", 结果1)  // 输出: 6

// 定义一个循环宏
定义宏 循环(n, 块)
    返回 引述
        设 i = 0
        当 i < $n
            $块
            i = i + 1

// 使用块宏
设 总和 = 0
!循环(5)
    总和 = 总和 + i
打印("循环5次求和:", 总和)  // 输出: 10

// 定义一个除非宏
定义宏 除非(条件, 代码块)
    返回 引述
        如果 不是 $条件
            $代码块

// 使用除非宏
设 温度 = 15
!除非(温度 > 20)
    打印("天气有点冷，请加衣服。")

// 测试可选参数
定义宏 可选参数(x, y=10)
    返回 引述
        $x + $y

设 结果2 = !可选参数(5)
设 结果3 = !可选参数(5, 20)
打印("可选参数(5):", 结果2)    // 输出: 15
打印("可选参数(5, 20):", 结果3) // 输出: 25
