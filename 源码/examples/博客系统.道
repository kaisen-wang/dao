// 道语言 - 综合示例：博客系统推荐引擎
// 演示：OOP + 函数式编程 + 逻辑编程 + 宏系统 多范式融合

打印("═" * 50)
打印("  道语言综合示例 - 博客系统推荐引擎")
打印("═" * 50)

// ===== S1: 模块导入 =====
从 时间 导入 计时器， 现在

// ===== S2: 面向对象编程 — 数据建模 =====

/// 文章类型：表示博客中的一篇文章
类型 文章
    初始化(标题, 作者, 标签)
        本对象.标题 = 标题
        本对象.作者 = 作者
        本对象.标签 = 标签
        本对象.创建时间 = 现在（）

    函数 转为文本()
        返回 `《{本对象.标题}》by {本对象.作者}`

// 推荐结果：包含文章和相关度分数
类型 推荐项
    初始化(文章, 分数)
        本对象.文章 = 文章
        本对象.分数 = 分数

    函数 转为文本()
        返回 `{本对象.文章.转为文本()} (相关度: {本对象.分数})`

// ===== S3: 逻辑编程 — 知识推理（双轨策略） =====

// --- 轨道A：逻辑编程语法演示（语法集成开发中，暂不可运行） ---
逻辑 推荐规则
    事实: 合作者("张三", "李四")
    事实: 合作者("李四", "王五")
    事实: 合作者("张三", "赵六")

    规则: 相关作者(?A, ?B) 如果 合作者(?A, ?B)
    规则: 相关作者(?A, ?B) 如果 合作者(?B, ?A)
    规则: 间接相关(?A, ?C) 如果
        合作者(?A, ?B) 并且 合作者(?B, ?C) 并且 ?A != ?C

查询(推荐规则, 相关作者("张三", ?B))

// --- 轨道B：OOP + 函数式替代方案（可运行） ---

// 合作者关系数据（双向关系）
定义 合作者关系 = [
    ["张三", "李四"],
    ["李四", "王五"],
    ["张三", "赵六"]
]

// 判断两人是否为直接合作者（双向检查）
函数 是合作者(甲, 乙)
    返回 存在满足(合作者关系, 函数(对) => (对[0] == 甲 并且 对[1] == 乙) 或者 (对[0] == 乙 并且 对[1] == 甲))

// 判断两人是否为间接相关（二度关系，排除直接合作和自身）
函数 是间接相关(甲, 乙)
    如果 甲 == 乙
        返回 假
    如果 是合作者(甲, 乙)
        返回 假
    定义 甲的合作者 = 筛选(合作者关系, 函数(对) => 对[0] == 甲 或者 对[1] == 甲)
    定义 中间人 = 映射(甲的合作者, 函数(对) => 取对方(对, 甲))
    返回 存在满足(中间人, 函数(中间) => 是合作者(中间, 乙))

// 辅助函数：从合作者对中取出对方的名字
函数 取对方(对, 名字)
    如果 对[0] == 名字
        返回 对[1]
    否则
        返回 对[0]

// ===== S4: 宏系统 — 横切关注点 =====

// 计时宏：自动测量代码块的执行耗时
定义宏 计时(名称, 代码块)
    返回 引述
        定义 __结果 = $代码块
        打印(`[性能] {$名称} 已完成`)
        __结果

// ===== S5: 函数式编程 — 推荐算法 =====

// 计算两篇文章之间的标签相似度（共同标签数量）
函数 标签相似度(文章甲, 文章乙)
    定义 甲集合 = 集合(文章甲.标签)
    定义 乙集合 = 集合(文章乙.标签)
    定义 共同 = 交集(甲集合, 乙集合)
    返回 长度(共同)

// 计算单篇候选文章的推荐分数
函数 计算分数(当前文章, 候选文章)
    定义 分数 = 0
    分数 = 分数 + 标签相似度(当前文章, 候选文章) * 10
    如果 是合作者(当前文章.作者, 候选文章.作者)
        分数 = 分数 + 50
    如果 不是 是合作者(当前文章.作者, 候选文章.作者) 并且 是间接相关(当前文章.作者, 候选文章.作者)
        分数 = 分数 + 20
    返回 分数

// 生成推荐列表
// 评分规则：共同标签 × 10 + 直接合作 +50 + 间接相关 +20
函数 生成推荐(当前文章, 所有文章)
    返回 所有文章
        |> 筛选(函数(a) => a.标题 != 当前文章.标题)
        |> 映射(函数(候选文章) => 推荐项(候选文章, 计算分数(当前文章, 候选文章)))
        |> 筛选(函数(项) => 项.分数 > 0)
        |> 排序(键=函数(项) => 项.分数, 降序=真)

// ===== 主程序：组合所有部分 =====

// 创建文章数据
定义 文章库 = [
    文章("道语言设计", "张三", ["编程", "语言设计", "中文"]),
    文章("虚拟机技术深入", "李四", ["编程", "性能优化"]),
    文章("AI 新进展", "王五", ["AI", "科技"]),
    文章("语言设计的未来", "赵六", ["语言设计", "未来趋势"]),
    文章("编程入门指南", "孙七", ["编程", "教育"]),
]

// 展示文章库
打印("\n📚 文章库:")
遍历 书 在 文章库
    打印("  " + 书.转为文本())

// 展示作者合作关系
打印("\n🤝 作者合作关系:")
遍历 对 在 合作者关系
    打印(`  {对[0]} ↔ {对[1]}`)

// 为"道语言设计"生成推荐
定义 目标文章 = 文章库[0]
打印(`\n🔍 为 {目标文章.转为文本()} 生成推荐:`)
打印("─" * 40)

// 使用计时宏包裹推荐逻辑（宏系统演示：无侵入式横切关注点）
!计时("推荐生成")
    定义 推荐列表 = 生成推荐(目标文章, 文章库)
    定义 序号 = 0
    遍历 推荐 在 推荐列表
        序号 = 序号 + 1
        打印(`  {序号}. {推荐.转为文本()}`)
    如果 长度(推荐列表) == 0
        打印("  暂无推荐")

