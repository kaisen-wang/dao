"""
@除非 宏示例
展示道语言内置 @除非 宏的用法
"""

打印("=== @除非 宏示例 ===")

// @除非 宏将条件取反，等价于"如果 不是 条件"
// 用法：!除非(条件) 代码块

// 示例1：基本用法
设 温度 = 15
!除非(温度 > 20)
    打印("天气冷，请穿外套")

// 示例2：与 如果 对比
设 分数 = 60
// 使用 如果
如果 分数 < 60
    打印("不及格")
// 使用 除非（等价写法）
!除非(分数 >= 60)
    打印("不及格")

// 示例3：复杂条件
设 用户 = {"名称": "张三", "年龄": 17}
!除非(用户["年龄"] >= 18 且 用户["名称"] != "")
    打印("用户信息不完整或未成年")

// 示例4：在函数中使用
函数 检查权限(角色)
    !除非(角色 == "管理员")
        打印("权限不足")
        返回 假
    返回 真

设 结果1 = 检查权限("普通用户")
设 结果2 = 检查权限("管理员")
打印("普通用户权限:", 结果1)
打印("管理员权限:", 结果2)
