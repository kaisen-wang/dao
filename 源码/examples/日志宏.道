"""
@日志 宏示例
展示道语言内置 @日志 宏的用法
"""

打印("=== @日志 宏示例 ===")

// @日志 宏在代码块执行前后自动添加日志输出
// 用法：!日志(函数名) 代码块

// 示例1：基本日志
设 结果1 = !日志("加法运算")
    1 + 2 + 3
打印("结果:", 结果1)

// 示例2：日志包裹函数调用
函数 处理数据(数据)
    设 总和 = 0
    遍历 项 在 数据
        总和 = 总和 + 项
    返回 总和

设 结果2 = !日志("数据处理")
    处理数据([10, 20, 30, 40, 50])
打印("数据总和:", 结果2)

// 示例3：日志包裹复杂操作
设 结果3 = !日志("字符串处理")
    设 文本 = "你好世界"
    文本.长度
打印("字符串长度:", 结果3)

// 示例4：日志与条件结合
函数 查找用户(名称)
    如果 名称 == "张三"
        返回 {"名称": "张三", "年龄": 25}
    返回 空

设 用户 = !日志("用户查找")
    查找用户("张三")
打印("找到用户:", 用户)
