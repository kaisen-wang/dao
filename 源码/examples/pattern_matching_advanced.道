// 道语言 - 模式匹配示例
// 演示列表模式匹配和字典模式匹配

// 列表模式匹配
定义 数据 = [1, 2, 3, 4, 5]

匹配 数据
    情况 [x, y, ...rest]
        打印("前两个:", x, y)
        打印("剩余:", rest)
    情况 [x]
        打印("单个元素:", x)
    情况 _
        打印("匹配任何值:", 数据)

// 字典模式匹配
定义 人 = {"姓名": "张三", "年龄": 25, "城市": "北京"}

匹配 人
    情况 {"姓名": 名字, "年龄": age}
        打印("姓名:", 名字)
        打印("年龄:", age)
    情况 {"姓名": 名字}
        打印("只有姓名:", 名字)
