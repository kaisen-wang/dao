// 运算符重载示例：向量运算
// ============================
// 这个示例展示了如何使用 运算符 关键字来重载运算符，
// 使自定义类型支持数学运算和比较操作。

// 定义向量类
类型 向量
    初始化(x, y)
        本对象.x = x
        本对象.y = y

    // 重载 + 运算符：向量加法
    运算符+(其他)
        返回 向量(本对象.x + 其他.x, 本对象.y + 其他.y)

    // 重载 - 运算符：向量减法
    运算符-(其他)
        返回 向量(本对象.x - 其他.x, 本对象.y - 其他.y)

    // 重载 * 运算符：标量乘法
    运算符*(标量)
        返回 向量(本对象.x * 标量, 本对象.y * 标量)

    // 重载 / 运算符：标量除法
    运算符/(标量)
        返回 向量(本对象.x / 标量, 本对象.y / 标量)

    // 重载 == 运算符：相等比较
    运算符==(其他)
        返回 本对象.x == 其他.x 并且 本对象.y == 其他.y

    // 重载 != 运算符：不等比较
    运算符!=(其他)
        返回 本对象.x != 其他.x 或者 本对象.y != 其他.y

    // 普通方法：获取长度
    函数 获取长度()
        返回 (本对象.x ** 2 + 本对象.y ** 2) ** 0.5

// 测试向量运算
定义 v1 = 向量(3, 4)
定义 v2 = 向量(1, 2)

打印("向量 v1: (" + v1.x + ", " + v1.y + ")")
打印("向量 v2: (" + v2.x + ", " + v2.y + ")")
打印

// 加法
定义 v3 = v1 + v2
打印("v1 + v2 = (" + v3.x + ", " + v3.y + ")")

// 减法
定义 v4 = v1 - v2
打印("v1 - v2 = (" + v4.x + ", " + v4.y + ")")

// 乘法（标量）
定义 v5 = v1 * 2
打印("v1 * 2 = (" + v5.x + ", " + v5.y + ")")

// 除法（标量）
定义 v6 = v1 / 2
打印("v1 / 2 = (" + v6.x + ", " + v6.y + ")")
打印

// 比较运算
定义 v7 = 向量(3, 4)
打印("v1 == v7: " + (v1 == v7))
打印("v1 != v2: " + (v1 != v2))
打印("v1 == v2: " + (v1 == v2))
打印

// 复合运算
定义 v8 = (v1 + v2) * 3
打印("(v1 + v2) * 3 = (" + v8.x + ", " + v8.y + ")")

// 计算向量长度
打印("v1 的长度: " + v1.获取长度())
