// 道语言 - 综合示例：图书管理系统
// 演示：OOP + 高阶函数 + 管道运算符 + 成员运算符 + 模式匹配

打印("═" * 50)
打印("  道语言综合示例 - 图书管理系统")
打印("═" * 50)

// ===== 数据模型 =====
类型 图书
    初始化(书名, 作者, 价格, 标签)
        本对象.书名 = 书名
        本对象.作者 = 作者
        本对象.价格 = 价格
        本对象.标签 = 标签

    函数 简介()
        返回 "《" + 本对象.书名 + "》" + 本对象.作者 + " ¥" + 文本(本对象.价格)

类型 书架
    初始化()
        本对象.书籍 = []

    函数 添加(书)
        追加(本对象.书籍, 书)

    函数 查找作者(作者名)
        返回 筛选(本对象.书籍, 函数(b) => b.作者 == 作者名)

    函数 按价格排序()
        返回 排序(本对象.书籍, 键=函数(b) => b.价格)

    函数 总价值()
        返回 折叠(本对象.书籍, 0, 函数(总, 书) => 总 + 书.价格)

    函数 统计数量()
        返回 长度(本对象.书籍)

// ===== 创建数据 =====
定义 架 = 书架()

架.添加(图书("道德经", "老子", 35, ["哲学", "经典"]))
架.添加(图书("论语", "孔子", 28, ["哲学", "经典"]))
架.添加(图书("三体", "刘慈欣", 69, ["科幻", "小说"]))
架.添加(图书("活着", "余华", 45, ["文学", "小说"]))
架.添加(图书("百年孤独", "马尔克斯", 55, ["文学", "外国"]))

// ===== 基本信息 =====
打印("\n📚 所有图书:")
遍历 书 在 架.书籍
    打印("  " + 书.简介())

打印("\n📊 总计: " + 文本(架.统计数量()) + " 本")
打印("💰 总价值: ¥" + 文本(架.总价值()))

// ===== 按价格排序 =====
打印("\n📈 按价格排序:")
定义 排好的 = 架.按价格排序()
遍历 书 在 排好的
    打印("  " + 书.简介())

// ===== 高阶函数查询 =====
打印("\n🔍 50元以上的书:")
定义 贵书 = 筛选(架.书籍, 函数(b) => b.价格 >= 50)
遍历 书 在 贵书
    打印("  " + 书.简介())

// ===== 管道运算符统计 =====
打印("\n📊 管道运算符统计:")
定义 平均价格 = 架.书籍 |> 映射(函数(b) => b.价格) |> 折叠(0, 函数(a, b) => a + b)
打印("  平均价格: ¥" + 文本(平均价格 / 架.统计数量()))

// ===== 标签搜索 =====
打印("\n🏷️ 含「哲学」标签的书:")
定义 哲学书 = 筛选(架.书籍, 函数(b) => "哲学" 在 b.标签)
遍历 书 在 哲学书
    打印("  " + 书.简介())

定义 小说 = 筛选(架.书籍, 函数(b) => "小说" 在 b.标签)
打印("\n📖 含「小说」标签的书:")
遍历 书 在 小说
    打印("  " + 书.简介())

// ===== 模式匹配：价格分类 =====
打印("\n💡 价格分类:")
函数 价格分类(价格)
    匹配 价格
        情况 _ 当 价格 < 30: 返回 "便宜"
        情况 _ 当 价格 < 50: 返回 "适中"
        情况 _: 返回 "较贵"

遍历 书 在 架.书籍
    打印("  " + 书.书名 + ": " + 价格分类(书.价格))

打印("\n✅ 程序执行完毕")
