"""
HTML构建器示例
展示道语言宏系统构建领域特定语言（DSL）的能力
使用宏来构建HTML结构
"""

打印("=== HTML构建器示例 ===")

// 定义HTML标签宏
定义宏 标签(标签名, 内容)
    返回 引述 "<" + $标签名 + ">" + $内容 + "</" + $标签名 + ">"

// 定义带属性的HTML标签宏
定义宏 标签带属性(标签名, 属性, 内容)
    返回 引述 "<" + $标签名 + " " + $属性 + ">" + $内容 + "</" + $标签名 + ">"

// 使用宏构建HTML
设 标题 = !标签("h1", "欢迎来到道语言")
设 段落1 = !标签("p", "道语言是一门中文编程语言")
设 段落2 = !标签("p", "宏系统让代码更优雅")

打印(标题)
打印(段落1)
打印(段落2)

// 构建嵌套结构
设 列表项1 = !标签("li", "简洁的中文语法")
设 列表项2 = !标签("li", "强大的宏系统")
设 列表项3 = !标签("li", "多范式支持")
设 列表内容 = 列表项1 + 列表项2 + 列表项3
设 无序列表 = !标签("ul", 列表内容)

打印(无序列表)

// 构建带属性的标签
设 链接 = !标签带属性("a", "href=\"https://example.com\"", "点击这里")
打印(链接)

// 构建完整页面
设 页面内容 = 标题 + 段落1 + 无序列表 + 段落2
设 页面 = !标签带属性("html", "lang=\"zh\"", !标签("body", 页面内容))
打印(页面)
