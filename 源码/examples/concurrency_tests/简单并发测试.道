异步 函数 发送(通道, 消息)
    发送 通道 消息
    打印("发送:", 消息)

异步 函数 接收(通道, 名称)
    定义 消息 = 接收 通道
    打印(名称, "收到:", 消息)
    返回 消息

异步 函数 主程序()
    定义 ch1 = 通道()
    定义 ch2 = 通道()

    并行
        发送(ch1, "消息1")

    并行
        发送(ch2, "消息2")

    定义 m1 = 接收(ch1, "接收方1")
    定义 m2 = 接收(ch2, "接收方2")

    打印("所有完成")

