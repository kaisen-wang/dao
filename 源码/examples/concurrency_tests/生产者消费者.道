// 生产者消费者示例
// 演示道语言的通道和协程间通信

导入 asyncio

异步 函数 生产者(名称, 通道, 数量)
    """生产数据并放入通道"""
    对于 i 在 范围(数量)
        数据 = 名称 + "-产品" + 字符串(i)
        打印("生产:", 数据)
        发送 通道 数据
        等待 asyncio.睡眠(0.1)  // 模拟生产耗时
    打印(名称, "生产完毕")

异步 函数 消费者(名称, 通道, 数量)
    """从通道消费数据"""
    对于 i 在 范围(数量)
        数据 = 接收 通道
        打印("消费:", 名称, "收到", 数据)
        等待 asyncio.睡眠(0.15)  // 模拟处理耗时
    打印(名称, "消费完毕")

异步 函数 基本生产消费()
    """基本的生产者-消费者模式"""
    打印("=== 基本生产者-消费者 ===")

    缓冲通道 = 通道(5)  // 容量为5的缓冲通道

    // 一个生产者，一个消费者
    并行
        生产者("生产者A", 缓冲通道, 8)
        消费者("消费者A", 缓冲通道, 8)

    打印("基本模式完成\n")

异步 函数 多生产者多消费者()
    """多个生产者和消费者"""
    打印("=== 多生产者-多消费者 ===")

    共享通道 = 通道(10)  // 容量为10的共享通道

    // 2个生产者，2个消费者
    并行
        生产者("生产者1", 共享通道, 5)
        生产者("生产者2", 共享通道, 5)
        消费者("消费者1", 共享通道, 5)
        消费者("消费者2", 共享通道, 5)

    打印("多生产者-多消费者模式完成\n")

异步 函数 信号量控制()
    """使用信号量控制并发数量"""
    打印("=== 信号量控制并发 ===")

    信号 = 信号量(2)  // 最多2个并发
    计数器 = 原子整数(0)

    异步 函数 受限任务(编号)
        信号.获取()
        当前并发 = 计数器.加(1)
        打印("任务", 编号, "开始，当前并发:", 当前并发)
        等待 asyncio.睡眠(0.3)
        打印("任务", 编号, "完成")
        计数器.加(-1)
        信号.释放()

    // 启动5个任务，但最多2个同时执行
    并行
        受限任务(1)
        受限任务(2)
        受限任务(3)
        受限任务(4)
        受限任务(5)

    打印("信号量控制完成\n")

异步 函数 等待组同步()
    """使用等待组同步多个协程"""
    打印("=== 等待组同步 ===")

    等待组 = 等待组()
    结果通道 = 通道(3)

    异步 函数 工作协程(名称)
        打印(名称, "开始工作")
        等待 asyncio.睡眠(0.2)
        打印(名称, "工作完成")
        发送 结果通道 名称
        等待组.完成()

    // 添加3个任务到等待组
    等待组.添加(3)

    并行
        工作协程("工人1")
        工作协程("工人2")
        工作协程("工人3")

    // 等待所有工作完成
    等待组.等待()
    打印("所有工人已完成工作")

    // 收集结果
    对于 i 在 范围(3)
        打印("结果:", 接收 结果通道)

    打印("等待组同步完成\n")

异步 函数 主程序()
    打印("=== 生产者消费者示例 ===\n")

    // 1. 基本生产消费
    等待 基本生产消费()

    // 2. 多生产者多消费者
    等待 多生产者多消费者()

    // 3. 信号量控制
    等待 信号量控制()

    // 4. 等待组同步
    等待 等待组同步()

    打印("=== 示例执行完毕 ===")

导入 time
开始事件循环()
运行异步(主程序())
