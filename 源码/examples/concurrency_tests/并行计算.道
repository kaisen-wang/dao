// 并行计算示例
// 演示道语言的并行块和原子操作

异步 函数 计算部分和(开始, 结束, 结果通道)
    """计算一个区间的和"""
    和 = 0
    对于 i 在 范围(开始, 结束)
        和 = 和 + i
    发送 结果通道 和

异步 函数 并行求和()
    """将大任务拆分为多个并行子任务"""
    打印("=== 并行求和 ===")

    总数 = 10000
    分片数 = 4
    每片大小 = 总数 // 分片数

    结果通道 = 通道(分片数)

    // 使用并行块同时计算
    并行
        计算部分和(0, 每片大小, 结果通道)
        计算部分和(每片大小, 每片大小 * 2, 结果通道)
        计算部分和(每片大小 * 2, 每片大小 * 3, 结果通道)
        计算部分和(每片大小 * 3, 总数, 结果通道)

    // 收集结果
    总和 = 0
    对于 i 在 范围(分片数)
        总和 = 总和 + 接收 结果通道

    打印("并行求和结果:", 总和)
    返回 总和

异步 函数 原子计数器()
    """使用原子操作实现线程安全的计数器"""
    打印("\n=== 原子计数器 ===")

    计数器 = 原子整数(0)
    屏障 = 屏障(4)  // 4个协程同步

    异步 函数 增加计数器(次数)
        屏障.等待()  // 等待所有协程就绪
        对于 i 在 范围(次数)
            计数器.加(1)

    // 4个协程各增加1000次
    并行
        增加计数器(1000)
        增加计数器(1000)
        增加计数器(1000)
        增加计数器(1000)

    打印("最终计数:", 计数器.获取())
    打印("预期值: 4000")

    如果 计数器.获取() == 4000
        打印("✅ 原子操作正确")
    否则
        打印("❌ 原子操作异常")

异步 函数 互斥锁保护()
    """使用互斥锁保护共享资源"""
    打印("\n=== 互斥锁保护共享资源 ===")

    锁 = 互斥锁()
    共享列表 = []

    异步 函数 安全添加(值)
        同步 锁
            共享列表.追加(值)

    并行
        安全添加("A")
        安全添加("B")
        安全添加("C")

    打印("共享列表:", 共享列表)
    打印("列表长度:", 长度(共享列表))

异步 函数 主程序()
    打印("=== 并行计算示例 ===\n")

    // 1. 并行求和
    等待 并行求和()

    // 2. 原子计数器
    等待 原子计数器()

    // 3. 互斥锁保护
    等待 互斥锁保护()

    打印("\n=== 示例执行完毕 ===")

