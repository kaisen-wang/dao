"""
并发编程测试程序
================

测试道语言的异步/等待、协程、通道、同步原语等并发编程功能。
"""

注：测试异步函数基本功能
异步函数 异步加法(x, y) {
    打印("异步加法开始")
    睡眠(0.5)
    结果 = x + y
    打印("异步加法完成:", 结果)
    返回 结果
}

异步函数 异步乘法(x, y) {
    打印("异步乘法开始")
    睡眠(0.8)
    结果 = x * y
    打印("异步乘法完成:", 结果)
    返回 结果
}

注：测试全部等待和竞速等待
异步函数 测试全部等待() {
    打印("测试全部等待")
    结果 = 等待 全部(
        异步加法(2, 3),
        异步乘法(4, 5),
        异步加法(10, 20)
    )
    打印("全部结果:", 结果)
}

异步函数 测试竞速等待() {
    打印("测试竞速等待")
    结果 = 等待 竞速(
        异步加法(2, 3),
        异步乘法(4, 5),
        异步加法(10, 20)
    )
    打印("竞速结果:", 结果)
}

注：测试通道通信
异步函数 发送者(通道) {
    打印("发送者开始")
    睡眠(0.3)
    发送 通道, "第一条消息"
    睡眠(0.2)
    发送 通道, "第二条消息"
    睡眠(0.1)
    发送 通道, "第三条消息"
    打印("发送者完成")
}

异步函数 接收者(通道) {
    打印("接收者开始")
    第一条 = 等待 通道
    打印("接收到:", 第一条)
    第二条 = 等待 通道
    打印("接收到:", 第二条)
    第三条 = 等待 通道
    打印("接收到:", 第三条)
    打印("接收者完成")
}

异步函数 测试通道() {
    打印("测试通道通信")
    通道 = 通道()
    等待 全部(
        发送者(通道),
        接收者(通道)
    )
}

注：测试缓冲通道
异步函数 测试缓冲通道() {
    打印("测试缓冲通道")
    通道 = 通道(2) 注：容量为 2 的缓冲通道

    发送 通道, "消息 1"
    发送 通道, "消息 2"

    打印("缓冲通道发送完成")

    打印("接收:", 等待 通道)
    打印("接收:", 等待 通道)
}

注：测试互斥锁
异步函数 测试互斥锁() {
    打印("测试互斥锁")

    锁 = 互斥锁()
    共享变量 = 0

    异步函数 增量() {
        打印("增量函数开始")
        锁.获取()
        打印("获取到锁")
        睡眠(0.2)
        共享变量 = 共享变量 + 1
        打印("共享变量:", 共享变量)
        锁.释放()
        打印("释放锁")
    }

    等待 全部(
        增量(),
        增量(),
        增量(),
        增量(),
        增量()
    )

    打印("最终共享变量:", 共享变量)
}

注：测试原子操作
异步函数 测试原子操作() {
    打印("测试原子操作")

    原子值 = 原子整数(0)

    异步函数 原子增量() {
        打印("原子增量函数开始")
        睡眠(0.1)
        原子值.加法(1)
        打印("原子值:", 原子值.获取())
    }

    等待 全部(
        原子增量(),
        原子增量(),
        原子增量(),
        原子增量(),
        原子增量()
    )

    打印("最终原子值:", 原子值.获取())
}

注：测试嵌套异步
异步函数 嵌套异步() {
    打印("第一层异步")
    结果1 = 等待 异步加法(10, 20)
    打印("第一层结果:", 结果1)

    异步函数 第二层异步() {
        打印("第二层异步")
        结果2 = 等待 异步乘法(结果1, 2)
        打印("第二层结果:", 结果2)
        返回 结果2
    }

    最终结果 = 等待 第二层异步()
    打印("最终结果:", 最终结果)
}

注：主函数
异步函数 主() {
    打印("==== 道语言并发编程测试 ====")

    测试结果 = []

    try {
        打印("\n1. 测试异步加法:")
        结果1 = 等待 异步加法(5, 3)
        打印("测试结果:", 结果1 == 8 ? "通过" : "失败")
        测试结果.追加("异步加法: " + (结果1 == 8 ? "通过" : "失败"))
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n2. 测试异步乘法:")
        结果2 = 等待 异步乘法(4, 6)
        打印("测试结果:", 结果2 == 24 ? "通过" : "失败")
        测试结果.追加("异步乘法: " + (结果2 == 24 ? "通过" : "失败"))
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n3. 测试全部等待:")
        结果3 = 等待 测试全部等待()
        测试结果.追加("全部等待: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n4. 测试竞速等待:")
        结果4 = 等待 测试竞速等待()
        测试结果.追加("竞速等待: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n5. 测试通道通信:")
        结果5 = 等待 测试通道()
        测试结果.追加("通道通信: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n6. 测试缓冲通道:")
        结果6 = 等待 测试缓冲通道()
        测试结果.追加("缓冲通道: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n7. 测试互斥锁:")
        结果7 = 等待 测试互斥锁()
        测试结果.追加("互斥锁: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n8. 测试原子操作:")
        结果8 = 等待 测试原子操作()
        测试结果.追加("原子操作: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    try {
        打印("\n9. 测试嵌套异步:")
        结果9 = 等待 嵌套异步()
        测试结果.追加("嵌套异步: 通过")
    } catch (异常) {
        打印("测试失败:", 异常)
    }

    注：打印测试总结
    打印("\n==== 测试总结 ====")
    总测试数 = 长度(测试结果)
    通过数 = 0
    for (测试 in 测试结果) {
        打印(测试)
        if ("通过" in 测试) {
            通过数 = 通过数 + 1
        }
    }
    打印(f"通过: {通过数} / {总测试数}")
    成功率 = (通过数 / 总测试数) * 100
    打印(f"成功率: {成功率:.0f}%")
}

注：运行测试
运行异步(主())
