// 异步网络请求示例
// 演示道语言的异步 HTTP 请求和并发处理

导入 asyncio

异步 函数 获取网页(网址)
    """模拟异步获取网页内容"""
    打印("开始获取:", 网址)
    等待 asyncio.睡眠(0.5)  // 模拟网络延迟
    打印("完成获取:", 网址)
    返回 "来自" + 网址 + "的内容"

异步 函数 并发请求()
    """并发请求多个网页"""
    打印("=== 并发请求多个网页 ===")

    网址列表 = [
        "https://example.com/api/1",
        "https://example.com/api/2",
        "https://example.com/api/3",
    ]

    // 创建所有请求任务
    任务列表 = []
    对于 网址 在 网址列表
        任务列表.追加(获取网页(网址))

    // 并发等待所有请求完成
    开始时间 = 时间.时间()
    结果 = 等待 全部(任务列表...)
    耗时 = 时间.时间() - 开始时间

    打印("所有请求完成，耗时:", 整数(耗时 * 1000), "毫秒")
    打印("结果数量:", 长度(结果))

    返回 结果

异步 函数 竞速请求()
    """竞速请求，使用最快返回的结果"""
    打印("\n=== 竞速请求 ===")

    // 模拟不同延迟的请求
    任务1 = 获取网页("https://fast-server.com/api")
    任务2 = 获取网页("https://slow-server.com/api")

    开始时间 = 时间.时间()
    最快结果 = 等待 竞速(任务1, 任务2)
    耗时 = 时间.时间() - 开始时间

    打印("最快结果:", 最快结果)
    打印("竞速耗时:", 整数(耗时 * 1000), "毫秒")

    返回 最快结果

异步 函数 带超时请求()
    """带超时的请求"""
    打印("\n=== 带超时的请求 ===")

    通道1 = 通道()
    通道2 = 通道()

    // 模拟异步发送数据到通道
    异步 函数 慢速生产者()
        等待 asyncio.睡眠(2.0)
        发送 通道1 "慢速数据"

    异步 函数 快速生产者()
        等待 asyncio.睡眠(0.3)
        发送 通道2 "快速数据"

    // 启动生产者
    等待 全部(慢速生产者(), 快速生产者())

    // 使用选择语句等待，带超时
    选择
        当 数据 = 接收 通道1
            打印("从通道1收到:", 数据)
        当 数据 = 接收 通道2
            打印("从通道2收到:", 数据)
        超时 1.0
            打印("请求超时！")

异步 函数 主程序()
    打印("=== 异步网络请求示例 ===\n")

    // 1. 并发请求
    并发结果 = 等待 并发请求()

    // 2. 竞速请求
    竞速结果 = 等待 竞速请求()

    // 3. 带超时请求
    等待 带超时请求()

    打印("\n=== 示例执行完毕 ===")

