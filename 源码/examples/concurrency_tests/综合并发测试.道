异步 函数 延迟执行(毫秒)
    打印("延迟执行:", 毫秒)
    返回 毫秒 * 2

异步 函数 计算阶乘(数字)
    定义 结果 = 1
    遍历 i 从 1 到 数字
        结果 = 结果 * i
    返回 结果

异步 函数 发送消息(通道, 消息, 延迟)
    打印("发送前等待:", 延迟, "毫秒")
    定义 结果 = 等待 延迟执行(延迟)
    发送 通道 消息
    打印("发送成功:", 消息)
    返回 结果

异步 函数 接收消息(通道, 接收方名称)
    打印("开始接收消息...")
    定义 消息 = 接收 通道
    打印(接收方名称, "收到:", 消息)
    返回 消息

异步 函数 竞速测试()
    打印("=== 竞速测试 ===")

    // 创建通道
    定义 通道1 = 通道()
    定义 通道2 = 通道()

    // 启动发送任务
    并行
        发送消息(通道1, "消息1", 1000)

    并行
        发送消息(通道2, "消息2", 500)

    // 竞速接收
    打印("等待第一个消息...")

    选择 {

        情况 接收 通道1 作为 消息:

            打印("通道1 获胜:", 消息)

        情况 接收 通道2 作为 消息:

            打印("通道2 获胜:", 消息)

        情况 超时(2000):

            打印("超时")
    }

异步 函数 并发执行测试()
    打印("=== 并发执行测试 ===")

    // 同时启动多个任务
    并行
        打印("任务1 结果:", 等待 延迟执行(1000))

    并行
        打印("任务2 结果:", 等待 计算阶乘(5))

    并行
        打印("任务3 结果:", 等待 延迟执行(1500))

异步 函数 通道通信测试()
    打印("=== 通道通信测试 ===")

    // 创建通道
    定义 数据通道 = 通道()

    // 启动发送和接收任务
    并行
        发送消息(数据通道, "Hello World!", 800)

    并行
        打印("接收结果:", 等待 接收消息(数据通道, "接收方A"))

异步 函数 通道缓冲测试()
    打印("=== 通道缓冲测试 ===")

    // 创建有缓冲的通道
    定义 缓冲通道 = 通道(2)

    // 发送不阻塞
    发送 缓冲通道 "缓冲消息1"
    发送 缓冲通道 "缓冲消息2"
    打印("两个消息发送成功（缓冲）")

    // 第三个发送会阻塞
    并行
        发送消息(缓冲通道, "缓冲消息3", 0)

    // 接收消息
    定义 消息1 = 接收 缓冲通道
    定义 消息2 = 接收 缓冲通道

    打印("接收消息1:", 消息1)
    打印("接收消息2:", 消息2)

    // 现在发送任务可以继续
    打印("所有消息处理完成")

