// 道语言 - 面向对象编程示例
// 演示：类型定义、继承、多态、方法调用

// ===== 基类：动物 =====
类型 动物
    初始化(名字, 年龄)
        本对象.名字 = 名字
        本对象.年龄 = 年龄

    函数 自我介绍()
        返回 本对象.名字 + "，" + 文本(本对象.年龄) + "岁"

    函数 叫声()
        返回 "..."

// ===== 子类：猫 =====
类型 猫 继承自 动物
    初始化(名字, 年龄, 颜色)
        父对象.初始化(名字, 年龄)
        本对象.颜色 = 颜色

    函数 叫声()
        返回 "喵~"

    函数 描述()
        返回 本对象.颜色 + "的" + 本对象.名字

// ===== 子类：狗 =====
类型 狗 继承自 动物
    初始化(名字, 年龄, 品种)
        父对象.初始化(名字, 年龄)
        本对象.品种 = 品种

    函数 叫声()
        返回 "汪汪!"

// ===== 主程序 =====
打印("═" * 40)
打印("  面向对象示例")
打印("═" * 40)

定义 小猫 = 猫("咪咪", 3, "白色")
定义 小狗 = 狗("旺财", 5, "金毛")

打印("猫: " + 小猫.自我介绍())
打印("描述: " + 小猫.描述())
打印("狗: " + 小狗.自我介绍())

// 多态：不同动物有不同的叫声
打印("\n动物们的叫声：")
定义 动物们 = [小猫, 小狗]
遍历 动物对象 在 动物们
    打印("  " + 动物对象.名字 + " 说: " + 动物对象.叫声())

// 是实例 检查
打印("\n类型检查：")
打印("小猫是猫？" + 文本(是实例(小猫, 猫)))
打印("小猫是动物？" + 文本(是实例(小猫, 动物)))
