// 道语言 - 模式匹配示例
// 演示：匹配/情况、通配符、守卫条件

打印("═" * 40)
打印("  模式匹配示例")
打印("═" * 40)

// ===== 基本匹配 =====
函数 星期几(数字)
    匹配 数字
        情况 1: 返回 "星期一"
        情况 2: 返回 "星期二"
        情况 3: 返回 "星期三"
        情况 4: 返回 "星期四"
        情况 5: 返回 "星期五"
        情况 6: 返回 "星期六"
        情况 7: 返回 "星期日"
        情况 _: 返回 "无效日期"

遍历 i 从 1 到 7
    打印(文本(i) + " → " + 星期几(i))

// ===== 成绩评级 =====
打印("\n成绩评级：")

函数 评级(分数)
    匹配 分数
        情况 _ 当 分数 >= 90: 返回 "优秀"
        情况 _ 当 分数 >= 80: 返回 "良好"
        情况 _ 当 分数 >= 70: 返回 "中等"
        情况 _ 当 分数 >= 60: 返回 "及格"
        情况 _: 返回 "不及格"

定义 测试分数 = [95, 85, 72, 60, 45]
遍历 分 在 测试分数
    打印(文本(分) + "分 → " + 评级(分))

// ===== 季节判断 =====
打印("\n季节判断：")

函数 季节(月份)
    匹配 月份
        情况 _ 当 月份 在 [3, 4, 5]: 返回 "春天 🌸"
        情况 _ 当 月份 在 [6, 7, 8]: 返回 "夏天 ☀️"
        情况 _ 当 月份 在 [9, 10, 11]: 返回 "秋天 🍂"
        情况 _ 当 月份 在 [12, 1, 2]: 返回 "冬天 ❄️"
        情况 _: 返回 "无效月份"

遍历 月 在 [3, 7, 10, 1]
    打印(文本(月) + "月 → " + 季节(月))
