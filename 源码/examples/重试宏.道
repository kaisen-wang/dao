"""
@重试 宏示例
展示道语言内置 @重试 宏的用法
"""

打印("=== @重试 宏示例 ===")

// @重试 宏在代码块执行失败时自动重试
// 用法：!重试(次数) 代码块

// 示例1：基本重试
设 尝试次数 = 0
函数 模拟连接()
    尝试次数 = 尝试次数 + 1
    打印("尝试连接... 第", 尝试次数, "次")
    如果 尝试次数 < 3
        抛出 "连接失败"
    返回 "连接成功"

设 连接结果 = !重试(3)
    模拟连接()
打印("最终结果:", 连接结果)

// 示例2：重试文件读取
设 读取次数 = 0
函数 读取配置()
    读取次数 = 读取次数 + 1
    如果 读取次数 < 2
        抛出 "文件被占用"
    返回 {"端口": 8080, "主机": "localhost"}

设 配置 = !重试(5)
    读取配置()
打印("配置:", 配置)

// 示例3：重试网络请求
设 请求次数 = 0
函数 获取数据()
    请求次数 = 请求次数 + 1
    如果 请求次数 < 4
        抛出 "网络超时"
    返回 [1, 2, 3]

设 数据 = !重试(5)
    获取数据()
打印("获取数据:", 数据)
