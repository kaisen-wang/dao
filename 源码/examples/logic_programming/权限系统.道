// 权限系统示例
// 展示逻辑编程中的否定（Negation as Failure）用法

逻辑 权限系统
    // 定义用户角色
    事实: 角色("张三", "管理员")
    事实: 角色("李四", "普通用户")
    事实: 角色("王五", "普通用户")

    // 定义封禁状态
    事实: 已封禁("王五")

    // 规则1：管理员始终有权限
    规则: 有权限(?用户) 如果
        角色(?用户, "管理员")

    // 规则2：普通用户且未被封禁才有权限
    // 使用"非"关键字实现否定（Negation as Failure）
    规则: 有权限(?用户) 如果
        角色(?用户, "普通用户") 并且 非 已封禁(?用户)

// 查询所有有权限的用户
定义 结果 = 查询(权限系统, 有权限(?谁))
遍历 解 在 结果
    打印(`有权限的用户: {解.谁}`)

// 预期输出：
// 有权限的用户: 张三
// 有权限的用户: 李四
// （王五虽然是普通用户，但已被封禁，所以不在结果中）

// 查询特定用户是否有权限
定义 张三权限 = 查询(权限系统, 有权限("张三"))
定义 王五权限 = 查询(权限系统, 有权限("王五"))

打印("张三有权限: " + (张三权限.长度 > 0 ? "是" : "否"))
打印("王五有权限: " + (王五权限.长度 > 0 ? "是" : "否"))
