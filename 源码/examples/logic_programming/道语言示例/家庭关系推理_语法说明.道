# -*- coding: utf-8 -*-
# 
# 家庭关系推理.道
# ================
#
# 这是一个使用道语言逻辑编程引擎的示例程序。
# 演示如何使用逻辑编程来推理家庭关系。
#
# 语法说明：
# ----------
# 1. 逻辑代码块：逻辑 名称 { ... }
# 2. 事实声明：事实: 谓词(参数)
# 3. 规则声明：规则: 谓词(参数) 如果 条件1 并且 条件2
# 4. 查询：查询(知识库, 目标)
#
# 示例代码：
# ---------
#
# # 定义家庭关系知识库
# 逻辑 家庭关系 {
#     # 声明事实
#     事实: 父母("张三", "小明")
#     事实: 父母("李四", "小明")
#     事实: 父母("张三", "小红")
#     事实: 父母("小明", "乐乐")
#     
#     # 定义规则：祖父母
#     # 祖父母(?祖, ?孙) 如果 父母(?祖, ?父) 并且 父母(?父, ?孙)
#     规则: 祖父母(?祖, ?孙) 如果 父母(?祖, ?父) 并且 父母(?父, ?孙)
# }
#
# # 查询1：张三的子女
# 定义 孩子们 = 查询(家庭关系, 父母("张三", ?谁))
# 遍历 结果 在 孩子们
#     打印("张三的孩子是: " + 结果.谁)
#
# # 查询2：张三的孙辈（通过规则推理）
# 定义 孙辈们 = 查询(家庭关系, 祖父母("张三", ?谁))
# 遍历 结果 在 孙辈们
#     打印("张三的孙辈是: " + 结果.谁)
#
# 运行结果：
# ---------
# 张三的孩子是: 小明
# 张三的孩子是: 小红
# 张三的孙辈是: 乐乐
#
