"""
道语言宏系统示例
展示道语言宏系统的核心功能和使用方法
"""

// ==================== 基础宏 ====================

// 定义一个简单的加一宏
定义宏 加一(x) {
    返回 引用 { $x + 1 }
}

// 使用宏
设 结果1 = 加一(5)
打印("加一(5):", 结果1)  // 输出: 6

// ==================== 块宏 ====================

// 定义一个循环宏
定义宏 循环(n, 块) {
    返回 引用 {
        设 i = 0
        当 i < $n {
            $块
            i = i + 1
        }
    }
}

// 使用块宏
设 总和 = 0
循环(5) {
    总和 = 总和 + i
}
打印("循环5次求和:", 总和)  // 输出: 10

// ==================== 引用与反引用 ====================

// 定义一个构建表达式的宏
定义宏 构建表达式(a, b) {
    返回 引用 {
        $a * $b + 引用{ $a }
    }
}

// 使用宏
设 结果2 = 构建表达式(2, 3)
打印("构建表达式(2, 3):", 结果2)  // 输出: 8 (2*3 + 2)

// ==================== 卫生宏 ====================

// 定义一个卫生宏
定义宏 卫生测试(x) {
    返回 引用 {
        设 temp = $x * 2
        temp
    }
}

// 测试卫生性
设 temp = 10
设 结果3 = 卫生测试(5)
打印("卫生测试(5):", 结果3)  // 输出: 10
打印("原始temp变量:", temp)  // 输出: 10 (未被宏中的temp覆盖)

// ==================== 多参数宏 ====================

// 定义一个多参数宏
定义宏 计算(a, b, c) {
    返回 引用 {
        ($a + $b) * $c
    }
}

// 使用多参数宏
设 结果4 = 计算(1, 2, 3)
打印("计算(1, 2, 3):", 结果4)  // 输出: 9 ((1+2)*3)

// ==================== 可选参数宏 ====================

// 定义一个带有可选参数的宏
定义宏 可选参数(x, y=10) {
    返回 引用 {
        $x + $y
    }
}

// 使用可选参数宏
设 结果5 = 可选参数(5)
设 结果6 = 可选参数(5, 20)
打印("可选参数(5):", 结果5)    // 输出: 15
打印("可选参数(5, 20):", 结果6) // 输出: 25

// ==================== 递归宏 ====================

// 定义一个递归宏
定义宏 递归宏(n) {
    返回 如果 n == 0 {
        引用 { 0 }
    } 否则 {
        引用 { $n + 递归宏($n - 1) }
    }
}

// 使用递归宏
设 结果7 = 递归宏(5)
打印("递归宏(5):", 结果7)  // 输出: 15 (5+4+3+2+1)

// ==================== 模式匹配宏 ====================

// 定义一个使用模式匹配的宏
定义宏 模式匹配宏(x) {
    返回 匹配 x {
        情况 0 { 引用 { "零" } }
        情况 1 { 引用 { "一" } }
        情况 2 { 引用 { "二" } }
        其他情况 { 引用 { "其他" } }
    }
}

// 使用模式匹配宏
设 结果8 = 模式匹配宏(1)
设 结果9 = 模式匹配宏(3)
打印("模式匹配宏(1):", 结果8)  // 输出: 一
打印("模式匹配宏(3):", 结果9)  // 输出: 其他

// ==================== 宏与管道结合 ====================

// 定义平方宏
定义宏 平方(x) {
    返回 引用 { $x * $x }
}

// 定义加五宏
定义宏 加五(x) {
    返回 引用 { $x + 5 }
}

// 使用管道操作符与宏结合
设 结果10 = 3 |> 平方 |> 加五
打印("3 |> 平方 |> 加五:", 结果10)  // 输出: 14 (3*3 +5)

// ==================== 复杂宏 ====================

// 定义一个构建函数的宏
定义宏 构建函数(name, 参数, 主体) {
    返回 引用 {
        函数 $name($参数) {
            $主体
        }
    }
}

// 使用宏构建函数
构建函数(计算面积, r, {
    返回 3.14 * r * r
})

设 面积 = 计算面积(5)
打印("计算面积(5):", 面积)  // 输出: 78.5

// 定义一个创建类的宏
定义宏 创建数据类(名称, 字段) {
    返回 引用 {
        类 $名称 {
            构造函数($字段) {
                遍历 (k, v) 在 $字段 |> 键值对 {
                    设 self.k = v
                }
            }

            方法 字符串表示() {
                返回 引用{ "$名称(" + 连接( $字段 |> 映射(k -> 字符串(self.k)), ", " ) + ")" }
            }
        }
    }
}

// 使用宏创建类
创建数据类(点, {x, y})

// 测试数据类
设 p = 点(3, 4)
打印("点(3, 4):", 字符串表示(p))  // 输出: 点(x=3, y=4)
