"""
道语言宏系统示例
展示道语言宏系统的核心功能和使用方法
"""

// ==================== 基础宏 ====================

// 定义一个简单的加一宏
定义宏 加一(x) {
    返回 引述 { $x + 1 }
}

// 使用宏
设 结果1 = !加一(5)
打印("加一(5):", 结果1)  // 输出: 6

// ==================== 块宏 ====================

// 定义一个循环宏
定义宏 循环(n, 块) {
    返回 引述 {
        设 i = 0
        当 i < $n {
            $块
            i = i + 1
        }
    }
}

// 使用块宏
设 总和 = 0
!循环(5) {
    总和 = 总和 + i
}
打印("循环5次求和:", 总和)  // 输出: 10

// ==================== 引述与注入 ====================

// 定义一个构建表达式的宏
定义宏 构建表达式(a, b) {
    返回 引述 {
        $a * $b + $a
    }
}

// 使用宏
设 结果2 = !构建表达式(2, 3)
打印("构建表达式(2, 3):", 结果2)  // 输出: 8 (2*3 + 2)

// ==================== 卫生宏 ====================

// 定义一个卫生宏
定义宏 卫生测试(x) {
    返回 引述 {
        设 temp = $x * 2
        temp
    }
}

// 测试卫生性
设 temp = 10
设 结果3 = !卫生测试(5)
打印("卫生测试(5):", 结果3)  // 输出: 10
打印("原始temp变量:", temp)  // 输出: 10 (未被宏中的temp覆盖)

// ==================== 多参数宏 ====================

// 定义一个多参数宏
定义宏 计算(a, b, c) {
    返回 引述 {
        ($a + $b) * $c
    }
}

// 使用多参数宏
设 结果4 = !计算(1, 2, 3)
打印("计算(1, 2, 3):", 结果4)  // 输出: 9 ((1+2)*3)

// ==================== 可选参数宏 ====================

// 定义一个带有可选参数的宏
定义宏 可选参数(x, y=10) {
    返回 引述 {
        $x + $y
    }
}

// 使用可选参数宏
设 结果5 = !可选参数(5)
设 结果6 = !可选参数(5, 20)
打印("可选参数(5):", 结果5)    // 输出: 15
打印("可选参数(5, 20):", 结果6) // 输出: 25

// ==================== 宏与管道结合 ====================

// 定义平方宏
定义宏 平方(x) {
    返回 引述 { $x * $x }
}

// 定义加五宏
定义宏 加五(x) {
    返回 引述 { $x + 5 }
}

// 使用管道操作符与宏结合
设 结果10 = 3 |> 平方 |> 加五
打印("3 |> 平方 |> 加五:", 结果10)  // 输出: 14 (3*3 +5)
