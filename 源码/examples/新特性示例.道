// 道语言 - 新特性示例
// 演示：模板字符串、解构赋值、静态方法、访问控制

打印("═" * 40)
打印("  新特性示例")
打印("═" * 40)

// ===== 模板字符串 =====
打印("\n📝 模板字符串：")
定义 名字 = "道语言"
定义 版本 = 1.0
打印(`欢迎使用{名字} v{版本}！`)

函数 问候(人名, 年龄)
    返回 `你好{人名}，你今年{年龄}岁了！`

打印(问候("张三", 25))
打印(`1 + 2 = {1 + 2}`)

// ===== 解构赋值 =====
打印("\n📦 解构赋值：")
定义 [甲, 乙, 丙] = [10, 20, 30]
打印(`甲={甲}, 乙={乙}, 丙={丙}`)

// 变量交换
定义 x = "左"
定义 y = "右"
打印(`交换前: x={x}, y={y}`)
[x, y] = [y, x]
打印(`交换后: x={x}, y={y}`)

// 函数返回多个值
函数 最大最小(列表)
    定义 最大值 = 列表[0]
    定义 最小值 = 列表[0]
    遍历 项 在 列表
        如果 项 > 最大值
            最大值 = 项
        如果 项 < 最小值
            最小值 = 项
    返回 [最小值, 最大值]

定义 [最小, 最大] = 最大最小([3, 1, 4, 1, 5, 9, 2, 6])
打印(`最小值: {最小}, 最大值: {最大}`)

// ===== 静态方法 =====
打印("\n🔧 静态方法：")

类型 数学工具
    静态 函数 圆面积(r)
        返回 3.14159 * r * r

    静态 函数 阶乘(n)
        如果 n <= 1
            返回 1
        返回 n * 数学工具.阶乘(n - 1)

打印(`半径5的圆面积: {数学工具.圆面积(5)}`)
打印(`5的阶乘: {数学工具.阶乘(5)}`)

// 静态工厂方法
类型 颜色
    初始化(r, g, b)
        本对象.r = r
        本对象.g = g
        本对象.b = b

    静态 函数 红色()
        返回 颜色(255, 0, 0)

    静态 函数 绿色()
        返回 颜色(0, 255, 0)

    函数 描述()
        返回 `RGB({本对象.r}, {本对象.g}, {本对象.b})`

定义 红 = 颜色.红色()
定义 绿 = 颜色.绿色()
打印(`红色: {红.描述()}`)
打印(`绿色: {绿.描述()}`)

// ===== 访问控制 =====
打印("\n🔒 访问控制：")

类型 银行账户
    初始化(户主, 初始余额)
        本对象.户主 = 户主
        本对象.余额 = 初始余额

    私有 函数 验证金额(金额)
        返回 金额 > 0

    函数 存款(金额)
        如果 本对象.验证金额(金额)
            本对象.余额 = 本对象.余额 + 金额
            打印(`{本对象.户主} 存入 ¥{金额}，余额: ¥{本对象.余额}`)
        否则
            打印("存款金额无效")

    函数 取款(金额)
        如果 本对象.验证金额(金额) 并且 金额 <= 本对象.余额
            本对象.余额 = 本对象.余额 - 金额
            打印(`{本对象.户主} 取出 ¥{金额}，余额: ¥{本对象.余额}`)
        否则
            打印("取款失败")

    函数 查询()
        返回 `{本对象.户主}的余额: ¥{本对象.余额}`

定义 账户 = 银行账户("张三", 1000)
账户.存款(500)
账户.取款(200)
打印(账户.查询())

// 测试外部无法直接调用私有方法
尝试
    账户.验证金额(100)
捕获 异常: err
    打印("✅ 私有方法已被正确保护")

打印("\n✅ 所有新特性演示完毕")
