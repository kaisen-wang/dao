// 模式匹配宏示例
// 演示道语言的模式匹配宏功能

// ========================
// 示例1：基础模式匹配宏 - 描述数值特征
// ========================

定义宏 描述(值) 匹配
    0 => 引述 "零"
    1 => 引述 "一"
    _ => 引述 "其他"

设 结果1 = !描述(0)
设 结果2 = !描述(1)
设 结果3 = !描述(42)

// ========================
// 示例2：列表解构宏 - 提取列表头部
// ========================

定义宏 头部(列表) 匹配
    [头, ...尾] => 引述 $头

设 列表头 = !头部([10, 20, 30])

// ========================
// 示例3：字典解构宏 - 提取字典字段
// ========================

定义宏 取名(数据) 匹配
    {"姓名": 名字} => 引述 $名字

设 名字 = !取名({"姓名": "张三", "年龄": 25})

// ========================
// 示例4：类型检查宏 - 根据类型分派
// ========================

定义宏 类型描述(值) 匹配
    类型:列表 => 引述 "是列表"
    类型:数值 => 引述 "是数值"
    类型:文本 => 引述 "是文本"
    _ => 引述 "未知类型"

设 类型1 = !类型描述([1, 2, 3])
设 类型2 = !类型描述(42)
设 类型3 = !类型描述("你好")

// ========================
// 示例5：守卫条件 - 带条件的模式匹配
// ========================

定义宏 分类(值) 匹配
    x 当 x > 0 => 引述 "正数"
    x 当 x < 0 => 引述 "负数"
    _ => 引述 "零"

设 分类1 = !分类(5)
设 分类2 = !分类(-3)
设 分类3 = !分类(0)
