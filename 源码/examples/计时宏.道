"""
@计时 宏示例
展示道语言内置 @计时 宏的用法
"""

打印("=== @计时 宏示例 ===")

// @计时 宏自动包裹计时逻辑，记录代码块执行耗时
// 用法：!计时(标签) 代码块

// 示例1：基本计时
设 结果1 = !计时("简单计算")
    1 + 2 + 3 + 4 + 5
打印("计算结果:", 结果1)

// 示例2：计时循环操作
设 总和 = 0
!计时("循环求和")
    设 i = 1
    当 i <= 100
        总和 = 总和 + i
        i = i + 1
打印("1到100的和:", 总和)

// 示例3：计时函数调用
函数 斐波那契(n)
    如果 n <= 1
        返回 n
    返回 斐波那契(n - 1) + 斐波那契(n - 2)

设 fib结果 = !计时("斐波那契(10)")
    斐波那契(10)
打印("斐波那契(10):", fib结果)

// 示例4：计时列表操作
设 数据 = [5, 3, 8, 1, 9, 2, 7, 4, 6]
!计时("列表排序")
    排序(数据)
打印("排序结果:", 数据)
