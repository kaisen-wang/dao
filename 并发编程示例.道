异步 函数 异步等待(毫秒)
    导入 asyncio
    等待 asyncio.睡眠(毫秒 / 1000)
    返回 毫秒

异步 函数 延迟执行(名称, 毫秒)
    打印("开始执行", 名称)
    结果 = 等待 异步等待(毫秒)
    打印("完成执行", 名称, "耗时", 结果, "毫秒")
    返回 结果

异步 函数 并发任务1()
    任务1 = 延迟执行("任务1", 1500)
    任务2 = 延迟执行("任务2", 1000)
    任务3 = 延迟执行("任务3", 2000)

    打印("等待所有任务完成")
    结果 = 等待 全部(任务1, 任务2, 任务3)
    打印("所有任务结果:", 结果)
    返回 结果

异步 函数 竞速任务()
    任务A = 延迟执行("任务A", 1500)
    任务B = 延迟执行("任务B", 1000)
    任务C = 延迟执行("任务C", 500)

    打印("等待最快任务完成")
    结果 = 等待 竞速(任务A, 任务B, 任务C)
    打印("最快任务结果:", 结果)
    返回 结果

异步 函数 嵌套调用()
    打印("开始嵌套调用")
    结果 = 等待 并发任务1()
    打印("并发任务结果:", 结果)

    打印("\n开始竞速任务")
    最快结果 = 等待 竞速任务()
    打印("竞速任务结果:", 最快结果)

    打印("\n所有嵌套调用完成")
    返回 [结果, 最快结果]

异步 函数 主程序()
    打印("=== 并发编程演示 ===")
    开始时间 = 时间.时间()

    打印("\n1. 测试异步函数延迟执行")
    延迟结果 = 等待 延迟执行("单个任务", 800)
    打印("延迟执行结果:", 延迟结果)

    打印("\n2. 测试并发执行（全部等待）")
    并发结果 = 等待 并发任务1()

    打印("\n3. 测试竞速执行（等待最快）")
    竞速结果 = 等待 竞速任务()

    打印("\n4. 测试嵌套调用")
    嵌套结果 = 等待 嵌套调用()

    总耗时 = 时间.时间() - 开始时间
    打印("\n=== 执行结果统计 ===")
    打印("总执行时间:", 整数(总耗时 * 1000), "毫秒")
    打印("延迟执行结果:", 延迟结果)
    打印("并发任务结果:", 并发结果)
    打印("竞速任务结果:", 竞速结果)
    打印("嵌套调用结果:", 嵌套结果)

    if 总耗时 < 5:
        打印("\n✅ 执行效率良好：总耗时", 整数(总耗时 * 1000), "毫秒")
    else:
        打印("\n⚠️  执行时间较长：总耗时", 整数(总耗时 * 1000), "毫秒")

