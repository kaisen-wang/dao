异步 函数 延迟执行(毫秒)
    打印("延迟执行:", 毫秒)
    返回 毫秒 * 2

异步 函数 发送(通道, 消息, 延迟)
    打印("发送前等待:", 延迟, "毫秒")
    等待 延迟执行(延迟)
    发送 通道 消息
    打印("发送成功:", 消息)
    返回 消息

异步 函数 接收(通道, 接收方)
    打印("开始接收...")
    定义 消息 = 接收 通道
    打印(接收方, "收到:", 消息)
    返回 消息

异步 函数 主程序()
    打印("=== 简单通道测试 ===")

    // 测试1: 基本发送和接收
    定义 通道1 = 通道()

    并行
        发送(通道1, "测试消息1", 500)

    定义 接收任务 = 接收(通道1, "接收方A")
    打印("主程序结果:", 接收任务)

    // 测试2: 缓冲通道
    打印("\n=== 缓冲通道测试 ===")
    定义 缓冲通道 = 通道(1)

    发送(缓冲通道, "缓冲消息1", 0)
    打印("缓冲消息1发送成功（非阻塞）")

    发送(缓冲通道, "缓冲消息2", 0)
    打印("缓冲消息2发送成功（非阻塞）")

    定义 接收结果 = 接收(缓冲通道, "接收方B")
    打印("接收结果:", 接收结果)

    定义 接收结果2 = 接收(缓冲通道, "接收方C")
    打印("接收结果2:", 接收结果2)

    print("\n✅ 所有通道测试通过!")

等待 主程序()
