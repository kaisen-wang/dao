异步 函数 竞速测试()
    打印("=== 竞速测试 ===")

    // 创建通道
    定义 通道1 = 通道()
    定义 通道2 = 通道()

    // 启动发送任务 - 使用并行语句
    并行
        发送消息(通道1, "消息1", 1000)
    并行
        发送消息(通道2, "消息2", 500)

    // 竞速接收
    打印("等待第一个消息...")

    选择 {
        情况 接收 通道1 作为 消息:
            打印("通道1 获胜:", 消息)
        情况 接收 通道2 作为 消息:
            打印("通道2 获胜:", 消息)
        情况 超时(2000):
            打印("超时")
    }

异步 函数 并发执行测试()
    打印("=== 并发执行测试 ===")

    // 同时启动多个任务 - 使用并行语句
    并行
        定义 任务1 = 延迟执行(1000)
    并行
        定义 任务2 = 计算阶乘(5)
    并行
        定义 任务3 = 延迟执行(1500)

    // 并发执行任务 - 这里直接使用任务变量，因为它们已经在并行块中执行了
    定义 结果1 = 任务1
    定义 结果2 = 任务2
    定义 结果3 = 任务3

    打印("任务1 结果:", 结果1)
    打印("任务2 结果:", 结果2)
    打印("任务3 结果:", 结果3)

