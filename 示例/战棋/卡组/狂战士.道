/// 狂战士卡组 — 高攻低防，速攻压制

从 实体.卡牌 导入 创建攻击卡牌, 创建防御卡牌, 创建技能卡牌, 元素类型
从 实体.角色 导入 玩家

导出 函数 创建狂战士牌组()
    返回 [
        创建攻击卡牌("猛击", 1, 8, 元素类型.火),
        创建攻击卡牌("猛击", 1, 8, 元素类型.火),
        创建攻击卡牌("连斩", 2, 5, 元素类型.风),
        创建攻击卡牌("连斩", 2, 5, 元素类型.风),
        创建攻击卡牌("狂暴", 3, 15),
        创建攻击卡牌("狂暴", 3, 15),
        创建防御卡牌("格挡", 1, 3),
        创建技能卡牌("战吼", 1, "本回合攻击力+5")
    ]

导出 函数 创建狂战士(名称)
    定义 角色 = 玩家(名称)
    角色.牌组 = 创建狂战士牌组()
    角色.攻击力 = 15
    角色.最大生命值 = 70
    角色.生命值 = 70
    返回 角色
