// 道语言 - 角色系统（OOP：类型/继承/抽象/受保护/静态）

从 实体.卡牌 导入 卡牌, 卡牌类型, 元素类型, 创建攻击卡牌, 创建防御卡牌, 创建技能卡牌
从 实体.状态效果 导入 效果类型, 效果

导出 抽象 类型 角色
    初始化(名称, 生命值, 攻击力, 防御力=0, 元素=元素类型.无)
        本对象.名称 = 名称
        本对象.最大生命值 = 生命值
        本对象.生命值 = 生命值
        本对象.攻击力 = 攻击力
        本对象.防御力 = 防御力
        本对象.力量 = 0
        本对象.护甲值 = 0
        本对象.元素 = 元素
        本对象.冻结 = 假
        本对象.手牌 = []
        本对象.牌组 = []
        本对象.效果列表 = []
        本对象.装备槽 = {}
        本对象.能量 = 3

    受保护 函数 实际伤害(原始伤害)
        定义 减伤 = 本对象.防御力 + 本对象.护甲值
        返回 最大值(0, 原始伤害 - 减伤)

    函数 受到伤害(伤害量)
        定义 最终伤害 = 本对象.实际伤害(伤害量)
        本对象.生命值 = 本对象.生命值 - 最终伤害
        本对象.事件("受到伤害", {"伤害": 最终伤害, "剩余": 本对象.生命值})
        返回 最终伤害

    函数 治疗(治疗量)
        本对象.生命值 = 最小值(本对象.最大生命值, 本对象.生命值 + 治疗量)

    函数 添加效果(效果)
        追加(本对象.效果列表, 效果)

    函数 更新效果()
        定义 剩余效果 = []
        遍历 效果 在 本对象.效果列表
            效果.应用(本对象)
            如果 效果.回合数() > 0
                追加(剩余效果, 效果)
            否则
                 效果.移除(本对象)
        本对象.效果列表 = 剩余效果

    函数 抽牌(数量=1)
        如果 长度(本对象.牌组) > 0
            定义 卡 = 本对象.牌组[0]
            定义 新牌组 = []
            遍历 i 从 1 到 长度(本对象.牌组) - 1
                追加(新牌组, 本对象.牌组[i])
            本对象.牌组 = 新牌组
            追加(本对象.手牌, 卡)

    函数 打牌(卡牌索引, 目标=空)
        如果 卡牌索引 < 长度(本对象.手牌)
            定义 卡 = 本对象.手牌[卡牌索引]
            如果 本对象.能量 >= 卡.花费
                本对象.能量 = 本对象.能量 - 卡.花费
                定义 新手牌 = []
                遍历 i 从 0 到 长度(本对象.手牌) - 1
                    如果 i != 卡牌索引
                        追加(新手牌, 本对象.手牌[i])
                本对象.手牌 = 新手牌
                本对象.使用卡牌效果(卡, 目标)
                返回 真
        返回 假

    函数 使用卡牌效果(卡牌, 目标)
        空

    函数 事件(事件名, 数据)
        空

    函数 存活()
        返回 本对象.生命值 > 0

    函数 描述()
        返回 `{本对象.名称} HP:{本对象.生命值}/{本对象.最大生命值} ATK:{本对象.攻击力} DEF:{本对象.防御力}`

导出 类型 玩家 继承自 角色
    初始化(名称)
        本对象.经验 = 0
        本对象.等级 = 1
        本对象.金币 = 0
        父对象.初始化(名称, 100, 10, 5)

    函数 获得经验(量)
        本对象.经验 = 本对象.经验 + 量
        如果 本对象.经验 >= 本对象.等级 * 50
            本对象.升级()

    私有 函数 升级()
        本对象.等级 = 本对象.等级 + 1
        本对象.最大生命值 = 本对象.最大生命值 + 20
        本对象.生命值 = 本对象.最大生命值
        本对象.攻击力 = 本对象.攻击力 + 3
        本对象.防御力 = 本对象.防御力 + 1

    函数 描述()
        返回 `{父对象.描述()} Lv.{本对象.等级} EXP:{本对象.经验}`

导出 类型 敌人 继承自 角色
    初始化(名称, 生命值, 攻击力, 防御力=0, 等级=1)
        父对象.初始化(名称, 生命值 * 等级, 攻击力 * 等级, 防御力 * 等级)
        本对象.等级 = 等级
        本对象.掉落经验 = 20 * 等级
        本对象.掉落金币 = 10 * 等级

    函数 AI行动(目标)
        如果 长度(本对象.手牌) > 0
            定义 卡 = 本对象.手牌[0]
            本对象.打牌(0, 目标)
        否则
            目标.受到伤害(本对象.攻击力)

    函数 描述()
        返回 `{父对象.描述()} Lv.{本对象.等级}`

导出 函数 创建默认牌组()
    返回 [
        创建攻击卡牌("打击", 1, 6),
        创建攻击卡牌("打击", 1, 6),
        创建攻击卡牌("打击", 1, 6),
        创建攻击卡牌("重击", 2, 12),
        创建防御卡牌("防御", 1, 5),
        创建防御卡牌("防御", 1, 5),
        创建防御卡牌("防御", 1, 5),
        创建技能卡牌("激怒", 1, "本回合攻击力+3")
    ]


