// 道语言 - AI 行为树
// 使用逻辑编程定义 AI 决策规则

导出 逻辑 战斗AI
    事实: 行动("攻击", "基础攻击")
    事实: 行动("防御", "防守态势")
    事实: 行动("技能", "释放技能")
    事实: 行动("撤退", "逃离战斗")

    事实: 状态("健康", 70)
    事实: 状态("受伤", 30)
    事实: 状态("危险", 0)

    规则: 可选行动(?行动, ?理由) 如果
        行动(?行动, ?理由)

导出 函数 AI选择行动(敌人, 玩家)
    定义 结果 = 查询(战斗AI, 可选行动(?行动, ?理由))
    定义 行动列表 = []
    遍历 解 在 结果
        追加(行动列表, 解.行动)

    如果 长度(行动列表) > 0
        返回 行动列表[0]
    返回 "攻击"

导出 函数 AI执行行动(敌人, 玩家, 行动)
    匹配 行动
        情况 "攻击"
            玩家.受到伤害(敌人.攻击力)
            返回 `{敌人.名称} 对 {玩家.名称} 发起攻击`
        情况 "防御"
            敌人.护甲值 = 敌人.护甲值 + 5
            返回 `{敌人.名称} 进入防御姿态`
        情况 "技能"
            如果 敌人.能量 >= 2
                敌人.能量 = 敌人.能量 - 2
                玩家.受到伤害(敌人.攻击力 * 1.5)
                返回 `{敌人.名称} 释放技能！`
            否则
                玩家.受到伤害(敌人.攻击力)
                返回 `{敌人.名称} 能量不足，改为普通攻击`
        情况 _
            玩家.受到伤害(敌人.攻击力)
            返回 `{敌人.名称} 发动攻击`
