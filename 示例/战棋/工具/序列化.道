// 道语言 - 序列化系统（标准库 file/JSON 存档读写）

从 核心.日志 导入 创建日志器
从 文件 导入 读取, 写入, 列出目录
从 编码 导入 JSON

导出 类型 存档管理器
    初始化(存档目录="存档/")
        本对象.存档目录 = 存档目录
        本对象.日志 = 创建日志器("存档管理器")

    函数 保存游戏(玩家, 引擎, 文件名="自动存档")
        定义 存档数据 = {
            "版本": "1.0.0",
            "时间戳": "Phase1",
            "回合数": 引擎.回合数,
            "玩家": 本对象.序列化玩家(玩家),
            "阶段": 引擎.阶段
        }
        定义 路径 = 本对象.存档目录 + 文件名 + ".json"
        尝试
            写入(路径, JSON.编码(存档数据, 缩进=2))
            本对象.日志.信息(`游戏已保存至 {路径}`)
            返回 真
        捕获 错误
            本对象.日志.错误(`保存失败: {错误}`)
            返回 假

    函数 加载游戏(文件名="自动存档")
        定义 路径 = 本对象.存档目录 + 文件名 + ".json"
        尝试
            定义 数据 = JSON.解码(读取(路径))
            本对象.日志.信息(`游戏已从 {路径} 加载`)
            返回 数据
        捕获 错误
            本对象.日志.错误(`加载失败: {错误}`)
            返回 空

    私有 函数 序列化玩家(玩家)
        返回 {
            "名称": 玩家.名称,
            "生命值": 玩家.生命值,
            "最大生命值": 玩家.最大生命值,
            "攻击力": 玩家.攻击力,
            "防御力": 玩家.防御力,
            "等级": 玩家.等级,
            "经验": 玩家.经验,
            "金币": 玩家.金币
        }

    函数 列出存档()
        尝试
            定义 所有文件 = 列出目录(本对象.存档目录)
            定义 json文件 = []
            遍历 f 在 所有文件
                如果 长度(f) >= 5
                    定义 末尾 = 长度(f) - 5
                    如果 f[末尾] == "." 并且 f[末尾+1] == "j" 并且 f[末尾+2] == "s" 并且 f[末尾+3] == "o" 并且 f[末尾+4] == "n"
                        追加(json文件, f)
            返回 json文件
        捕获
            返回 []

导出 函数 创建存档管理器(目录="存档/")
    返回 存档管理器(目录)
