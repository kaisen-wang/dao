// 道语言 - 网络对战系统（Phase 3: 通道通信 + 超时选择 + 异步对战房间）

从 核心.日志 导入 创建日志器
从 实体.角色 导入 玩家
从 实体.角色 导入 创建默认牌组
从 数学 导入 随机小数

// ========================
// 行动类型常量
// ========================

导出 常量 行动类型 = {
    "攻击": "攻击",
    "防御": "防御",
    "技能": "技能",
    "抽牌": "抽牌"
}

// ========================
// 对战房间（同步对战逻辑）
// ========================

导出 类型 对战房间
    初始化(房间名, 回合上限=15)
        本对象.日志 = 创建日志器(`[{房间名}]`)
        本对象.房间名 = 房间名
        本对象.回合上限 = 回合上限
        本对象.回合 = 1
        本对象.胜者 = 空

    函数 执行行动(行动者, 目标, 行动名)
        匹配 行动名
            情况 行动类型.攻击
                定义 伤害 = 行动者.攻击力 + 整数(随机小数() * 行动者.攻击力 / 2)
                目标.受到伤害(伤害)

            情况 行动类型.防御
                行动者.护甲值 = 行动者.护甲值 + 5

            情况 行动类型.技能
                如果 行动者.能量 >= 2
                    行动者.能量 = 行动者.能量 - 2
                    定义 伤害 = 行动者.攻击力 * 2 + 3
                    目标.受到伤害(伤害)
                否则
                    目标.受到伤害(行动者.攻击力)

            情况 行动类型.抽牌
                行动者.抽牌(1)
                行动者.能量 = 行动者.能量 + 1

        行动者.能量 = 最小值(行动者.能量 + 2, 10)

        如果 不是 目标.存活()
            本对象.结束(行动者.名称, `{目标.名称} 被击败`)
        否则 如果 不是 行动者.存活()
            本对象.结束(目标.名称, `{行动者.名称} 被击败`)

    函数 结束(胜者名, 原因)
        如果 本对象.胜者 != 空
            返回
        本对象.胜者 = 胜者名
        本对象.日志.信息(`{胜者名} 获胜 ({原因})`)

// ========================
// AI 决策
// ========================

导出 函数 AI决策(角色, 对手)
    如果 角色.生命值 < 对手.攻击力 * 2
        返回 行动类型.防御
    否则 如果 角色.能量 >= 2 并且 角色.生命值 > 对手.生命值
        返回 行动类型.技能
    否则
        返回 行动类型.攻击

// ========================
// 同步 AI vs AI（自动对战演示）
// ========================

导出 函数 AIvsAI(名1="勇者", 名2="哥布林")
    定义 日志 = 创建日志器("AI对战")
    日志.信息(`启动 {名1} vs {名2}`)

    定义 甲 = 玩家(名1)
    甲.牌组 = 创建默认牌组()
    甲.抽牌(3)

    定义 乙 = 玩家(名2)
    乙.牌组 = 创建默认牌组()
    乙.抽牌(3)

    定义 房间 = 对战房间(`{名1}vs{名2}`, 回合上限=20)

    遍历 i 从 1 到 房间.回合上限
        定义 甲行动 = AI决策(甲, 乙)
        定义 乙行动 = AI决策(乙, 甲)

        房间.日志.信息(`=== 第 {房间.回合} 回合 ===`)
        房间.日志.信息(`{甲.名称} -> {甲行动}`)
        房间.执行行动(甲, 乙, 甲行动)
        如果 房间.胜者 != 空
            跳出

        房间.日志.信息(`{乙.名称} -> {乙行动}`)
        房间.执行行动(乙, 甲, 乙行动)
        如果 房间.胜者 != 空
            跳出

        房间.回合 = 房间.回合 + 1
        甲.能量 = 最小值(甲.能量 + 2, 10)
        乙.能量 = 最小值(乙.能量 + 2, 10)

    如果 房间.胜者 == 空
        定义 胜者名 = 甲.名称 如果 甲.生命值 > 乙.生命值 否则 乙.名称
        房间.胜者 = 胜者名

    日志.信息(`{房间.胜者} 获胜！`)
    返回 房间.胜者

// ============================================================
// Phase 3: 通道通信 + 超时选择
// 演示：通道、发送、接收、选择、超时 等并发语法
// ============================================================

// ============================================================
// 单回合对战逻辑（抽出为单独函数以避免选择在循环体中）
// ============================================================

导出 函数 执行单回合(房间, 甲, 乙, 甲通道, 乙通道)
    // AI 决策后通过通道发送行动
    定义 甲行动 = AI决策(甲, 乙)
    发送 甲通道 甲行动

    定义 乙行动 = AI决策(乙, 甲)
    发送 乙通道 乙行动

    // 使用选择器接收甲的行动（带超时保护）
    定义 接收甲 = 空
    选择
        情况 接收 甲通道 作为 动作:
            设 接收甲 = 动作
        情况 超时(5):
            房间.日志.信息(`{甲.名称} 超时`)
            房间.结束(乙.名称, `{甲.名称} 超时`)
            返回 "超时"

    如果 房间.胜者 != 空
        返回 "结束"

    // 使用选择器接收乙的行动（带超时保护）
    定义 接收乙 = 空
    选择
        情况 接收 乙通道 作为 动作:
            设 接收乙 = 动作
        情况 超时(5):
            房间.日志.信息(`{乙.名称} 超时`)
            房间.结束(甲.名称, `{乙.名称} 超时`)
            返回 "超时"

    如果 房间.胜者 != 空
        返回 "结束"

    // 执行双方行动
    房间.日志.信息(`{甲.名称} -> {接收甲}`)
    房间.执行行动(甲, 乙, 接收甲)
    如果 房间.胜者 != 空
        返回 "结束"

    房间.日志.信息(`{乙.名称} -> {接收乙}`)
    房间.执行行动(乙, 甲, 接收乙)
    如果 房间.胜者 != 空
        返回 "结束"

    甲.能量 = 最小值(甲.能量 + 2, 10)
    乙.能量 = 最小值(乙.能量 + 2, 10)
    返回 "继续"

// ============================================================
// 通道对战：使用通道通信 + 超时选择的回合制对战
// 演示：通道、发送、接收、选择、超时 等并发语法
// ============================================================

导出 函数 通道对战(名1="勇者", 名2="哥布林", 回合上限=20)
    定义 日志 = 创建日志器("通道对战")
    日志.信息(`启动通道对战 {名1} vs {名2}`)

    定义 甲 = 玩家(名1)
    甲.牌组 = 创建默认牌组()
    甲.抽牌(3)

    定义 乙 = 玩家(名2)
    乙.牌组 = 创建默认牌组()
    乙.抽牌(3)

    定义 房间 = 对战房间(`{名1}vs{名2}(通道)`, 回合上限)

    // 创建两个缓冲通道模拟玩家通信
    定义 甲通道 = 通道(5)
    定义 乙通道 = 通道(5)

    遍历 i 从 1 到 回合上限
        房间.日志.信息(`=== 第 {i} 回合 ===`)
        定义 结果 = 执行单回合(房间, 甲, 乙, 甲通道, 乙通道)
        如果 结果 != "继续"
            跳出

    如果 房间.胜者 == 空
        定义 胜者名 = 甲.名称 如果 甲.生命值 > 乙.生命值 否则 乙.名称
        房间.胜者 = 胜者名

    日志.信息(`{房间.胜者} 获胜！`)
    返回 房间.胜者
