/// 道语言 - 战棋游戏入口（Phase 4: 完整游戏循环）
/// 回合制策略游戏（卡牌对战/杀戮尖塔风格）

从 核心.引擎 导入 创建引擎, 游戏阶段
从 核心.日志 导入 创建日志器
从 核心.事件 导入 创建事件总线
从 实体.角色 导入 玩家, 敌人, 创建默认牌组
从 实体.卡牌 导入 创建攻击卡牌, 创建防御卡牌, 创建技能卡牌, 卡牌类型, 元素类型
从 实体.技能 导入 创建技能, 火球术, 治疗术
从 实体.装备 导入 武器, 防具, 装备槽位
从 实体.状态效果 导入 燃烧, 冰冻, 力量加成, 护盾
从 战斗.计算器 导入 计算伤害, 格式化伤害结果, 计算最终伤害
从 工具.序列化 导入 创建存档管理器
从 卡组.狂战士 导入 创建狂战士牌组

// Phase 2: DSL 宏
从 DSL.技能定义 导入 技能, 增益
从 DSL.事件脚本 导入 事件分类
从 DSL.条件模板 导入 血量低, 能量充足

// Phase 2: AI 行为树（逻辑编程）
从 战斗.行为树 导入 战斗AI, AI选择行动, AI执行行动

// Phase 2: 卡牌效果（模式匹配）
从 战斗.卡牌效果 导入 执行卡牌效果, 计算元素克制

// Phase 3: 网络对战
从 并发.网络对战 导入 AIvsAI, 通道对战

导出 函数 主()
    定义 日志 = 创建日志器("战棋")
    日志.信息("战棋游戏启动 (Phase 4)")

    // === Phase 2 DSL 演示 ===
    定义 火球技能 = !技能("火球", 30, "火", 20, "攻击")
    日志.信息(`DSL 技能定义: {火球技能.描述}`)

    定义 事件分类结果 = !事件分类("回合开始")
    日志.信息(`DSL 事件分类: {事件分类结果}`)

    // 逻辑编程查询（非 约束演示）
    定义 AI行动结果 = 查询(战斗AI, 可选行动(?行动, ?理由))
    遍历 解 在 AI行动结果
        日志.信息(`AI 知识库: {解.行动} - {解.理由}`)

    // === 游戏初始化 ===
    定义 游戏引擎 = 创建引擎()
    定义 存档 = 创建存档管理器()

    定义 当前玩家 = 玩家("勇者")
    当前玩家.牌组 = 创建狂战士牌组()
    当前玩家.抽牌(5)

    定义 当前敌人 = 敌人("哥布林", 30, 6, 2, 1)

    日志.信息(当前玩家.描述())
    日志.信息(当前敌人.描述())

    // 事件系统：使用引擎主循环驱动的回调架构
    定义 出牌阶段回调 = 函数(数据) =>
        // 出牌阶段逻辑
        打印(`--- 玩家回合 ---`)
        打印(当前玩家.描述())
        打印(当前敌人.描述())
        打印(`能量: {当前玩家.能量}`)

        如果 长度(当前玩家.手牌) > 0
            定义 手牌卡 = 当前玩家.手牌[0]
            定义 效果描述 = 执行卡牌效果(当前玩家, 当前敌人, 手牌卡)
            打印(效果描述)

        定义 出牌成功 = 当前玩家.打牌(0, 当前敌人)
        如果 出牌成功
            打印("打出卡牌！")
        否则
            打印("能量不足或无手牌")

        对于 i 在 范围(1, 4)
            当前玩家.能量 = 当前玩家.能量 + 1
            // 用 继续 跳过后续叠加
            如果 i >= 2
                继续
    游戏引擎.事件总线.注册("出牌阶段", 出牌阶段回调)

    定义 敌方回合回调 = 函数(数据) =>
        // 敌方回合逻辑
        打印(`--- 敌方回合 ---`)
        定义 AI行动 = AI选择行动(当前敌人, 当前玩家)
        定义 AI描述 = AI执行行动(当前敌人, 当前玩家, AI行动)
        打印(AI描述)
        打印(`玩家HP: {当前玩家.生命值}/{当前玩家.最大生命值}`)

        // 伤害计算管道
        定义 上下文 = 计算伤害(当前玩家, 当前敌人, 5)
        打印(格式化伤害结果(上下文))
    游戏引擎.事件总线.注册("敌方回合", 敌方回合回调)

    定义 回合开始回调 = 函数(回合) =>
        日志.信息(`=== 第 {回合} 回合 ===`)
        当前玩家.能量 = 3
        当前玩家.抽牌(2)
        当前玩家.更新效果()
        当前敌人.更新效果()
        当前敌人.抽牌(1)
    游戏引擎.事件总线.注册("回合开始", 回合开始回调)

    定义 阶段回调 = 函数(阶段) =>
        日志.信息(`游戏阶段: {阶段}`)
    游戏引擎.事件总线.注册("阶段变化", 阶段回调)

    // 引擎主循环驱动游戏
    游戏引擎.启动()
    断言 游戏引擎.存活, "游戏引擎未启动"
    断言 当前玩家.存活() 并且 当前敌人.存活(), "初始角色必须存活"

    游戏引擎.主循环(当前玩家, 当前敌人)

    // 结束判定（或者 条件演示）
    如果 当前敌人.存活() 或者 不是 当前玩家.存活()
        日志.信息("游戏结束 - 玩家败北")
    否则
        日志.信息("游戏结束 - 玩家胜利！")

    // 最终块测试：确保存档始终执行
    尝试
        存档.保存游戏(当前玩家, 游戏引擎)
        日志.信息("游戏已保存")
    最终
        日志.信息("保存操作完成")

    // Phase 3: AI 自动对战
    日志.信息("启动 AI 自动对战演示 (同步)...")
    定义 胜者 = AIvsAI("勇者", "哥布林")
    日志.信息(`AI 对战胜者: {胜者}`)

    // Phase 3: 通道对战
    日志.信息("启动通道对战演示 (通道+选择+超时)...")
    定义 通道胜者 = 通道对战("勇者", "哥布林", 10)
    日志.信息(`通道对战胜者: {通道胜者}`)

主()
