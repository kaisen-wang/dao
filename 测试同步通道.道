异步 函数 延迟执行(毫秒)
    打印("延迟执行:", 毫秒)
    返回 毫秒 * 2

异步 函数 发送(通道, 消息)
    发送 通道 消息
    打印("发送成功:", 消息)
    返回 消息

异步 函数 接收(通道, 接收方)
    打印("开始接收...")
    定义 消息 = 接收 通道
    打印(接收方, "收到:", 消息)
    返回 消息

异步 函数 主程序()
    打印("=== 同步通道测试 ===")

    // 创建通道
    定义 通道1 = 通道()

    // 发送任务
    并行
        发送(通道1, "测试消息1")

    // 接收任务
    定义 接收结果 = 接收(通道1, "接收方A")
    打印("主程序结果:", 接收结果)

    // 缓冲通道测试
    打印("\n=== 缓冲通道测试 ===")
    定义 缓冲通道 = 通道(2)

    // 发送两个消息
    发送(缓冲通道, "缓冲消息1")
    发送(缓冲通道, "缓冲消息2")
    打印("两个缓冲消息发送成功")

    // 接收消息
    定义 消息1 = 接收(缓冲通道, "接收方B")
    定义 消息2 = 接收(缓冲通道, "接收方C")

    打印("接收1:", 消息1)
    打印("接收2:", 消息2)

    print("\n✅ 所有同步通道测试通过!")

等待 主程序()
